# ──────────────────────────────────────────────────────────────────────────────
# FinoLens Backend — Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# URL of the React frontend (used for CORS whitelist)
FRONTEND_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL 16+ required.
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://finolens:finolens_secret@localhost:5432/finolens

# ── Cache ─────────────────────────────────────────────────────────────────────
# Redis 7+ required.
REDIS_URL=redis://localhost:6379

# How long to cache ML signals (seconds). Default 300 = 5 minutes.
CACHE_TTL_SECONDS=300

# ── ML Service ────────────────────────────────────────────────────────────────
# FastAPI service that provides market data, signals, and SuperTrend.
ML_SERVICE_URL=http://localhost:8000

# ── Data Source / Broker ──────────────────────────────────────────────────────
# 'yfinance'  — free, no credentials needed (default)
# 'zerodha'   — live broker integration
# 'angel'     — Angel One broker integration
BROKER=yfinance

# Zerodha Kite Connect (only required when BROKER=zerodha)
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_ACCESS_TOKEN=

# Angel One SmartAPI (only required when BROKER=angel)
ANGEL_CLIENT_ID=
ANGEL_MPIN=
ANGEL_TOTP_SECRET=

# ── Algo Engine ───────────────────────────────────────────────────────────────
# Whether to run the algo engine on server start (true | false)
ALGO_ENGINE_ENABLED=true

# Override market hours check for testing outside NSE hours (true | false)
ALGO_ENGINE_FORCE_OPEN=false
